# ============================================================
# OOMSmartPot Backend Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Gemini AI (Required for AI features) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- Arduino Serial Port ---
SERIAL_PORT=/dev/ttyACM0
SERIAL_BAUD=9600

# --- Pump GPIO Pin (BCM numbering) ---
PUMP_GPIO_PIN=26

# --- Database ---
DATABASE_URL=sqlite:///./smartpot.db

# --- Force Mock Mode (set to true for development without hardware) ---
MOCK_HARDWARE=false
